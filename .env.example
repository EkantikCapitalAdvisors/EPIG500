# Supabase (form storage). When unset, email capture renders success-state stub.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Resend (transactional email). When unset, no confirmation email is sent.
RESEND_API_KEY=
RESEND_FROM_EMAIL=

# Cal.com scheduler URL. When unset, primary CTA falls back to mailto.
NEXT_PUBLIC_SCHEDULER_URL=
NEXT_PUBLIC_FALLBACK_EMAIL=hiren@ekantikcapital.com

# Plausible (analytics). When unset, events are no-op (logged to console in dev).
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=
